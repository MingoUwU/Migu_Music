{
  "name": "migu-music",
  "version": "2.0.4",
  "author": "TrungNam",
  "description": "MiGu Music Player",
  "main": "main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/MingoUwU/Migu_Music.git"
  },
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "server": "node server.js",
    "build": "electron-builder --win",
    "pack": "electron-builder --win --dir"
  },
  "build": {
    "appId": "com.migu.music",
    "productName": "MiGu Music",
    "copyright": "Copyright © 2024 MingoUwU",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "MiGu Music"
    },
    "asarUnpack": [
      "node_modules/youtube-dl-exec/**/*"
    ],
    "files": [
      "main.js",
      "server.js",
      "public/**/*",
      "package.json",
      "node_modules/youtube-dl-exec/**/*",
      "node_modules/@aspect/**/*"
    ],
    "extraResources": [
      {
        "from": "node_modules/youtube-dl-exec/bin",
        "to": "bin"
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "MingoUwU",
        "repo": "Migu_Music"
      }
    ]
  },
  "dependencies": {
    "cors": "^2.8.5",
    "discord-rpc": "^4.0.1",
    "electron-updater": "^6.8.3",
    "express": "^4.21.0",
    "express-rate-limit": "^7.5.1",
    "node-fetch": "^2.7.0",
    "youtube-dl-exec": "^3.0.12"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  }
}
